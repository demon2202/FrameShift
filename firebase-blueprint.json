{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" },
        "followers": { "type": "number" },
        "following": { "type": "number" },
        "isTrending": { "type": "boolean" },
        "isPrivate": { "type": "boolean" },
        "followRequests": { "type": "array", "items": { "type": "string" } },
        "bannerUrl": { "type": "string" },
        "isWinner": { "type": "boolean" },
        "blockedUsers": { "type": "array", "items": { "type": "string" } },
        "feedPreferences": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "username", "name"]
    },
    "Poster": {
      "title": "Poster",
      "description": "A poster uploaded by a user",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "creatorId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "license": { "type": "string", "enum": ["personal", "commercial"] },
        "likes": { "type": "number" }
      },
      "required": ["title", "imageUrl", "creatorId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a poster",
      "type": "object",
      "properties": {
        "posterId": { "type": "string" },
        "userId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["posterId", "userId", "text", "createdAt"]
    },
    "Collection": {
      "title": "Collection",
      "description": "A moodboard or collection of posters",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "isPrivate": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "posterIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "Thread": {
      "title": "Thread",
      "description": "A chat conversation between users",
      "type": "object",
      "properties": {
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "lastMessageTime": { "type": "string", "format": "date-time" },
        "unreadCount": { "type": "object" },
        "typing": { "type": "object" }
      },
      "required": ["participantIds"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a thread",
      "type": "object",
      "properties": {
        "threadId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" },
        "posterId": { "type": "string" }
      },
      "required": ["threadId", "senderId", "text", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["like", "follow", "message", "system", "comment"] },
        "actorId": { "type": "string" },
        "targetUserId": { "type": "string" },
        "referenceId": { "type": "string" },
        "read": { "type": "boolean" },
        "time": { "type": "string", "format": "date-time" },
        "text": { "type": "string" }
      },
      "required": ["type", "targetUserId", "time"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a poster",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "posterId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "posterId"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followingId"]
    },
    "Story": {
      "title": "Story",
      "description": "A temporary story uploaded by a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "viewers": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "userId", "imageUrl", "timestamp", "viewers"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/stories/{storyId}": {
      "schema": { "$ref": "#/entities/Story" },
      "description": "Temporary stories uploaded by users"
    },
    "/posters/{posterId}": {
      "schema": { "$ref": "#/entities/Poster" },
      "description": "Posters uploaded by users"
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Comments on posters"
    },
    "/collections/{collectionId}": {
      "schema": { "$ref": "#/entities/Collection" },
      "description": "User collections/moodboards"
    },
    "/threads/{threadId}": {
      "schema": { "$ref": "#/entities/Thread" },
      "description": "Chat conversations"
    },
    "/threads/{threadId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages within a conversation"
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "User notifications"
    },
    "/likes/{likeId}": {
      "schema": { "$ref": "#/entities/Like" },
      "description": "Likes on posters"
    },
    "/follows/{followId}": {
      "schema": { "$ref": "#/entities/Follow" },
      "description": "Follow relationships"
    }
  }
}
